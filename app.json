{
  "expo": {
    "name": "GeoARViewer",
    "slug": "geo-ar-viewer",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "android": {
      "package": "com.wsp.geoarviewer",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ]
    }
  }
}
